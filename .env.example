NUXT_PUBLIC_API_BASE_URL=https://api.solian.app

# OAuth provider display name
NUXT_PUBLIC_OAUTH_PROVIDER_NAME=Solarpass

# Database (PostgreSQL required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goatshed

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# OIDC Provider (Solarpass / Solian)
SOLIAN_CLIENT_ID=
SOLIAN_CLIENT_SECRET=

# Admin emails (comma-separated). Users with these emails are auto-promoted to admin.
ADMIN_EMAILS=
