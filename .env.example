NUXT_PUBLIC_API_BASE_URL=https://api.solian.app

# OAuth provider endpoints (FloatingIsland)
NUXT_PUBLIC_OAUTH_PROVIDER_NAME=FloatingIsland
NUXT_PUBLIC_OAUTH_CLIENT_ID=
NUXT_OAUTH_CLIENT_SECRET=
NUXT_PUBLIC_OAUTH_AUTHORIZE_URL=https://id.solian.app/auth/authorize
NUXT_PUBLIC_OAUTH_TOKEN_URL=https://api.solian.app/padlock/auth/open/token
NUXT_PUBLIC_OAUTH_USER_INFO_URL=https://api.solian.app/padlock/auth/open/userinfo
NUXT_PUBLIC_OAUTH_SCOPE=openid profile email
NUXT_PUBLIC_OAUTH_REDIRECT_URL=

# Session signing secret for this blog app
NUXT_AUTH_SESSION_SECRET=replace-this-with-a-long-random-secret

# Optional OAuth debug logging (1/true)
NUXT_OAUTH_DEBUG=0
